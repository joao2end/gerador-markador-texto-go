{
  "$schema": "https://opencode.ai/config.json",
  "username": "joaobatista",

  "default_agent": "marcador-loop",

  "agent": {
    "marcador-loop": {
      "description": "Loop de iteração para Marcador Tubular — executa, testa, diagnostica e corrige até todos os requisitos passarem.",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "external_directory": "allow"
      }
    }
  },

  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "allow",
    "glob": "allow",
    "grep": "allow",
    "external_directory": "allow"
  }
}
